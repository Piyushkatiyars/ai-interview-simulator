# AI Interview Simulator - Environment Variables

# Application
APP_NAME=AI Interview Simulator
DEBUG=true

# Database - Local Development
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=interview_simulator

# Database - AWS RDS (Production)
# AWS_RDS_HOST=your-rds-instance.region.rds.amazonaws.com
# AWS_RDS_PORT=3306
# AWS_RDS_USER=admin
# AWS_RDS_PASSWORD=your_secure_password
# AWS_RDS_DATABASE=interview_simulator

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-key-change-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# OpenAI API (for AI-powered features)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Bcrypt
BCRYPT_ROUNDS=12
